{
  "name": "@anlyx/adapter-openapi",
  "version": "0.1.3",
  "description": "OpenAPI Basic Support adapter for Anlyx endpoint and schema imports.",
  "author": "suhannoh",
  "license": "MIT",
  "keywords": [
    "anlyx",
    "openapi",
    "developer-tools",
    "api-flow"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs . && tsc -p tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suhannoh/anlyx.git",
    "directory": "packages/adapter-openapi"
  },
  "homepage": "https://github.com/suhannoh/anlyx#readme",
  "bugs": {
    "url": "https://github.com/suhannoh/anlyx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@anlyx/core": "workspace:*"
  }
}
