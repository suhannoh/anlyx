{
  "name": "@anlyx/ui",
  "version": "0.1.6-beta.1",
  "description": "React UI components and local viewer shell for Anlyx.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs . && tsc -p tsconfig.build.json && node ./scripts/copy-viewer-assets.mjs && node ../cli/node_modules/vite/bin/vite.js build --config vite.overlay.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suhannoh/anlyx.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/suhannoh/anlyx#readme",
  "bugs": {
    "url": "https://github.com/suhannoh/anlyx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./capture-runtime": {
      "types": "./dist/capture/capture-runtime.d.ts",
      "default": "./dist/capture/capture-runtime.js"
    },
    "./viewer": "./dist/viewer/viewer.html"
  },
  "dependencies": {
    "@anlyx/core": "workspace:*",
    "@xyflow/react": "^12.9.0",
    "elkjs": "^0.11.1",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "react-resizable-panels": "^4.11.2",
    "sigma": "^3.0.3",
    "simple-icons": "^16.24.1"
  },
  "peerDependencies": {
    "react": ">=18.3.0 <20",
    "react-dom": ">=18.3.0 <20"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^27.3.0"
  }
}
