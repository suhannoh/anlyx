{
  "name": "@anlyx/ui",
  "version": "0.1.2",
  "description": "React UI components and local viewer shell for Anlyx.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs . && tsc -p tsconfig.build.json && node ./scripts/copy-viewer-assets.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suhannoh/anlyx.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/suhannoh/anlyx#readme",
  "bugs": {
    "url": "https://github.com/suhannoh/anlyx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./viewer": "./dist/viewer/viewer.html"
  },
  "dependencies": {
    "@anlyx/core": "workspace:*",
    "@xyflow/react": "^12.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^27.3.0"
  }
}
